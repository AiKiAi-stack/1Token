{
  "name": "1token",
  "version": "0.1.1",
  "private": true,
  "bin": {
    "1token": "./cli/cli-tool.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
